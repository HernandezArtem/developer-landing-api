# ── App ──────────────────────────────────────────────────────
APP_NAME="Developer Landing API"
APP_VERSION="1.0.0"
DEBUG=false

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ── Email (mail.ru SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your@mail.ru
SMTP_PASSWORD=your_smtp_password
OWNER_EMAIL=your@mail.ru

# ── DeepSeek AI (primary) ─────────────────────────────────────
DEEPSEEK_API_KEY=sk-...your_deepseek_key...
DEEPSEEK_MODEL=deepseek-chat

# ── OpenRouter AI (fallback) ──────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...your_openrouter_key...
OPENROUTER_MODEL=mistralai/mistral-nemo
AI_TIMEOUT=15

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=900

# ── MySQL (Beget Cloud DB) ────────────────────────────────────
# Локально оставьте пустым — данные пишутся в data/*.json
# На VPS укажите строку подключения (приватная сеть Beget: 10.x.x.x)
# Спецсимволы в пароле URL-кодируйте (& → %26)
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@10.x.x.x:3306/DB_NAME
DATABASE_URL=
