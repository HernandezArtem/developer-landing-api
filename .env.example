# ── App ──────────────────────────────────────────────────────
APP_NAME="Developer Landing API"
APP_VERSION="1.0.0"
DEBUG=false

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ── Email (mail.ru SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your@mail.ru
SMTP_PASSWORD=your_smtp_password
OWNER_EMAIL=your@mail.ru

# ── OpenRouter AI (Mistral Nemo) ──────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...your_openrouter_key...
OPENROUTER_MODEL=mistralai/mistral-nemo
AI_TIMEOUT=15

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=900

# ── MySQL (Beget Cloud DB) ────────────────────────────────────
# Если задан — contacts, metrics, rate_limits хранятся в MySQL.
# Пример (приватная сеть Beget): mysql+pymysql://USER:PASSWORD@10.x.x.x:3306/DB_NAME
# Пример (публичный доступ):     mysql+pymysql://USER:PASSWORD@public-host.beget.com:3306/DB_NAME
DATABASE_URL=
